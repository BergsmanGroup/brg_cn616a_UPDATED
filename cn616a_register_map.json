        { "offset_hex": "0x05", "type": "R", "access": "R", "name": "current_segment_state", "enum": "segment_state" },
        { "offset_hex": "0x06", "type": "F", "access": "RW", "name": "deadband", "default": 0.0 },
        { "offset_hex": "0x08", "type": "F", "access": "RW", "name": "sp_abs", "default": 0.0 },
        { "offset_hex": "0x0a", "type": "F", "access": "RW", "name": "sp_ctl", "default": 0.0 },
        { "offset_hex": "0x0c", "type": "F", "access": "RW", "name": "p_gain", "default": 1.0 },
        { "offset_hex": "0x0e", "type": "F", "access": "RW", "name": "i_gain", "default": 0.0 },
        { "offset_hex": "0x10", "type": "F", "access": "RW", "name": "d_gain", "default": 0.0 },
        { "offset_hex": "0x12", "type": "F", "access": "RW", "name": "out_pct", "default": 0.0 },
        { "offset_hex": "0x14", "type": "F", "access": "RW", "name": "cycle_time_s", "default": 5.0, "notes": "Applies to all zones" },
        { "offset_hex": "0x16", "type": "R", "access": "RW", "name": "autotune_enable", "enum": "autotune_control" },
        { "offset_hex": "0x17", "type": "R", "access": "R", "name": "loop_status", "enum": "loop_status" },
        { "offset_hex": "0x18", "type": "F", "access": "RW", "name": "autotune_sp", "default": 0.0 },
        { "offset_hex": "0x1a", "type": "R", "access": "RW", "name": "control_mode", "enum": "control_mode" },
        { "offset_hex": "0x1b", "type": "F", "access": "R", "name": "ramp_soak_remaining" }
      ]
    },
    "profile_registers": {
      "description": "Ramp/Soak profile registers for zones 1..6, 20 segments, 3 parameters per segment",
      "supported_zones": 6,
      "profile_bases_index_hex": {
        "1": "0x1000",
        "2": "0x1100",
        "3": "0x1200",
        "4": "0x1300",
        "5": "0x1400",
        "6": "0x1500"
      },
      "segment_offsets_hex": {
        "segment_1": "0x00",
        "segment_20": "0x13"
      },
      "formula": "addr = base + 6*segment_offset + field_offset",
      "fields": [
        { "field_offset_hex": "0x00", "type": "F", "access": "RW", "name": "seg_sp", "default": 0.0 },
        { "field_offset_hex": "0x02", "type": "F", "access": "RW", "name": "seg_slope_deg_per_min", "default": 10.0 },
        { "field_offset_hex": "0x04", "type": "F", "access": "RW", "name": "seg_time_hours", "default": 1.0 }
      ]
