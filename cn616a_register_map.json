        { "offset_hex": "0x02", "type": "F", "access": "RW", "name": "alarm_sp_low", "default": -900.0 },
        { "offset_hex": "0x04", "type": "R", "access": "RW", "name": "alarm1_mode", "enum": "alarm_type" },
        { "offset_hex": "0x05", "type": "R", "access": "RW", "name": "alarm1_latch", "enum": "setting_toggle" },
        { "offset_hex": "0x06", "type": "R", "access": "RW", "name": "alarm1_status", "enum": "alarm_status" },
        { "offset_hex": "0x07", "type": "R", "access": "RW", "name": "alarm2_mode", "enum": "alarm_type" },
        { "offset_hex": "0x08", "type": "R", "access": "RW", "name": "alarm2_latch", "enum": "setting_toggle" },
        { "offset_hex": "0x09", "type": "R", "access": "RW", "name": "alarm2_status", "enum": "alarm_status" },
        { "offset_hex": "0x0a", "type": "F", "access": "RW", "name": "current_scale_high", "default": 20.0 },
        { "offset_hex": "0x0c", "type": "F", "access": "RW", "name": "current_scale_low", "default": 4.0 },
        { "offset_hex": "0x0e", "type": "F", "access": "RW", "name": "voltage_scale_high", "default": 1000.0 },
        { "offset_hex": "0x10", "type": "F", "access": "RW", "name": "voltage_scale_low", "default": 0.0 }
      ]
    },
    "pid_registers": {
      "description": "PID/control registers repeated for zones 1..6",
      "supported_zones": 6,
      "zone_bases_index_hex": {
        "1": "0x0800",
        "2": "0x0880",
        "3": "0x0900",
        "4": "0x0980",
        "5": "0x0a00",
        "6": "0x0a80"
