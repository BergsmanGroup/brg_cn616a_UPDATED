{
  "map_version": "cn616a_modbus_map_v1",
  "device": {
    "model": "Omega CN616A",
    "channels": 6,
    "zones_max_reported": [6, 12]
  },
  "protocol": {
    "transport": "Modbus RTU",
    "holding_register_base": 40000,
    "byte_order": "big_endian",
    "word_order_32bit": "MSW_first",
    "function_codes": {
      "read_holding": 3,
      "write_single": 6,
      "write_multiple": 16
    },
    "data_types": {
      "R": { "registers": 1, "bits": 16, "notes": "bool/byte/char/int16/uint16" },
      "L": { "registers": 2, "bits": 32, "notes": "int32/uint32, MSW first" },
      "F": { "registers": 2, "bits": 32, "notes": "IEEE-754 float, MSW first" },
      "B": { "registers": "n", "bits": "8n", "notes": "byte array" }
    },
    "dual_register_access_rules": {
      "read_fc03": "Request starting at the lower-numbered (base) register and read at least 2 registers.",
      "write_fc16": "Write starting at the lower-numbered (base) register and write at least 2 registers.",
      "split_read_fc03": "If split into single-register reads, you must read base first; reading the next reg returns the buffered LSW bytes.",
      "split_write_fc06": "If split into single-register writes, writing base buffers but does not commit; writing the next reg commits the full 32-bit value."
    }
  },
  "registers": {
    "system": [
      { "index_hex": "0x0001", "holding_register": 40001, "type": "R", "access": "R", "name": "device_description" },
      { "index_hex": "0x0002", "holding_register": 40002, "type": "R", "access": "R", "name": "fw_version_major_minor" },
      { "index_hex": "0x0003", "holding_register": 40003, "type": "R", "access": "R", "name": "fw_version_minor_fix" },
      { "index_hex": "0x0005", "holding_register": 40005, "type": "R", "access": "R", "name": "max_zones" },
      { "index_hex": "0x0006", "holding_register": 40006, "type": "R", "access": "RW", "name": "temperature_scale", "enum": "process_unit" },
      { "index_hex": "0x0007", "holding_register": 40007, "type": "R", "access": "RW", "name": "sensor_type", "enum": "sensor_type" },
      { "index_hex": "0x0008", "holding_register": 40008, "type": "R", "access": "RW", "name": "sensor_subtype", "enum_hint": "thermocouple_type_or_rtd_type" },
      { "index_hex": "0x0009", "holding_register": 40009, "type": "R", "access": "RW", "name": "password" },
      { "index_hex": "0x000a", "holding_register": 40010, "type": "R", "access": "RW", "name": "modbus_address" },
      { "index_hex": "0x000b", "holding_register": 40011, "type": "R", "access": "RW", "name": "scan_time_seconds" },
      { "index_hex": "0x000c", "holding_register": 40012, "type": "R", "access": "RW", "name": "active_zone_bitmap" },
      { "index_hex": "0x0015", "holding_register": 40021, "type": "R", "access": "RW", "name": "system_state", "enum": "system_state" },
      { "index_hex": "0x0016", "holding_register": 40022, "type": "R", "access": "RW", "name": "startup_state", "enum": "system_state" },
      { "index_hex": "0x0018", "holding_register": 40024, "type": "R", "access": "RW", "name": "system_alarm_type", "enum": "alarm_type" },
      { "index_hex": "0x0019", "holding_register": 40025, "type": "R", "access": "RW", "name": "system_alarm_latch", "enum": "setting_toggle" },
      { "index_hex": "0x001a", "holding_register": 40026, "type": "R", "access": "RW", "name": "password_enable", "enum": "setting_toggle" },
      { "index_hex": "0x001b", "holding_register": 40027, "type": "R", "access": "RW", "name": "decimal_point", "enum": "decimal_point" }
    ],
    "temperature_pv": {
      "description": "Per-zone Process Value (PV)",
      "zone_count_max": 12,
      "pattern": {
        "zone_1_index_hex": "0x0100",
        "index_step_hex": "0x0002",
        "type": "F",
        "access": "R",
        "name": "pv"
      }
    },
    "sensor_status": {
      "description": "Per-zone sensor status + bitmaps",
      "zone_1_index_hex": "0x0180",
      "zone_step_hex": "0x0001",
      "type": "R",
      "access": "R",
      "enum": "sensor_status",
      "bitmaps": [
        { "index_hex": "0x018c", "holding_register": 40396, "type": "R", "access": "R", "name": "sensor_status_bitmap" },
        { "index_hex": "0x018d", "holding_register": 40397, "type": "R", "access": "R", "name": "alarm_status_bitmap" }
      ]
    },
    "zone_registers": {
      "description": "Zone-specific registers repeated for up to 12 zones",
      "zone_bases_index_hex": {
        "1": "0x0200",
        "2": "0x0280",
        "3": "0x0300",
        "4": "0x0380",
        "5": "0x0400",
        "6": "0x0480",
        "7": "0x0500",
        "8": "0x0580",
        "9": "0x0600",
        "10": "0x0680",
        "11": "0x0700",
        "12": "0x0780"
      },
      "fields": [
